          "content": {
            "size": 32660,
            "mimeType": "text/css",
            "text": "/* ============================================================\n   Rafael Feltrim — Portfolio\n   Obsidian Glow · Premium · SDET Senior\n   ============================================================ */\n\n:root {\n  /* Obsidian palette */\n  --bg:        #050505;\n  --bg-2:      #080808;\n  --bg-3:      #0d0d0d;\n  --bg-card:   #0a0a0a;\n  --border:    rgba(255,255,255,0.06);\n  --border-2:  rgba(255,255,255,0.10);\n\n  --text:      #e8eaf0;\n  --text-muted:#7a8494;\n  --text-dim:  #3d4455;\n\n  /* Obsidian Glow — roxo premium */\n  --accent:      #3A0CA3;\n  --accent-mid:  #6d28d9;\n  --accent-light:#a78bfa;\n  --accent-dim:  rgba(58,12,163,0.18);\n  --accent-glow: rgba(109,40,217,0.35);\n  --accent-border: rgba(109,40,217,0.3);\n\n  /* Supporting accents */\n  --teal:      #2dd4bf;\n  --teal-dim:  rgba(45,212,191,0.10);\n  --amber:     #fbbf24;\n  --amber-dim: rgba(251,191,36,0.10);\n  --green:     #34d399;\n  --pink:      #f472b6;\n\n  --font-mono: 'JetBrains Mono', monospace;\n  --font-sans: 'Inter', sans-serif;\n\n  --radius:    12px;\n  --radius-lg: 20px;\n  --shadow:    0 4px 32px rgba(0,0,0,0.7);\n  --shadow-lg: 0 8px 64px rgba(0,0,0,0.8);\n  --glow-sm:   0 0 20px rgba(109,40,217,0.25);\n  --glow-md:   0 0 40px rgba(109,40,217,0.3);\n}\n\n/* ── Reset ── */\n*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }\nhtml { scroll-behavior: smooth; scroll-padding-top: 72px; }\nbody {\n  font-family: var(--font-sans);\n  background: var(--bg);\n  color: var(--text);\n  line-height: 1.7;\n  overflow-x: hidden;\n}\na { color: inherit; text-decoration: none; }\nul { list-style: none; }\n\n/* ── Scrollbar ── */\n::-webkit-scrollbar { width: 4px; }\n::-webkit-scrollbar-track { background: var(--bg); }\n::-webkit-scrollbar-thumb { background: var(--accent); border-radius: 2px; }\n\n/* ── Container ── */\n.container { max-width: 1080px; margin: 0 auto; padding: 0 24px; }\n\n/* ── Selection ── */\n::selection { background: rgba(109,40,217,0.35); color: #fff; }\n\n/* ============================================================\n   NAVBAR\n   ============================================================ */\n#navbar {\n  position: fixed;\n  top: 0; left: 0; right: 0;\n  z-index: 100;\n  padding: 20px 0;\n  transition: background 0.3s, padding 0.3s, box-shadow 0.3s;\n}\n#navbar.scrolled {\n  background: rgba(5,5,5,0.95);\n  backdrop-filter: blur(16px);\n  -webkit-backdrop-filter: blur(16px);\n  padding: 12px 0;\n  border-bottom: 1px solid var(--border);\n}\n.nav-inner {\n  max-width: 1080px; margin: 0 auto; padding: 0 24px;\n  display: flex; align-items: center; justify-content: space-between;\n}\n.nav-logo {\n  font-family: var(--font-mono);\n  font-size: 1.4rem; font-weight: 700;\n  color: var(--text); letter-spacing: -1px;\n}\n.nav-logo-dot { color: var(--accent-light); }\n\n.nav-links { display: flex; gap: 4px; align-items: center; }\n.nav-links a {\n  font-family: var(--font-mono); font-size: 0.8rem;\n  color: var(--text-muted); padding: 6px 12px;\n  border-radius: 6px; transition: color 0.2s, background 0.2s;\n}\n.nav-links a:hover, .nav-links a.active { color: var(--text); background: rgba(255,255,255,0.05); }\n.nav-cta {\n  background: var(--accent-dim) !important;\n  color: var(--accent-light) !important;\n  border: 1px solid var(--accent-border) !important;\n}\n.nav-cta:hover {\n  background: var(--accent) !important;\n  color: #fff !important;\n  box-shadow: var(--glow-sm) !important;\n}\n\n.nav-toggle {\n  display: none; flex-direction: column; gap: 5px;\n  background: none; border: none; cursor: pointer; padding: 4px;\n}\n.nav-toggle span {\n  display: block; width: 22px; height: 2px;\n  background: var(--text); border-radius: 2px;\n  transition: transform 0.25s, opacity 0.25s;\n}\n.nav-toggle.active span:nth-child(1) { transform: translateY(7px) rotate(45deg); }\n.nav-toggle.active span:nth-child(2) { opacity: 0; }\n.nav-toggle.active span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }\n\n.mobile-menu {\n  display: none; position: fixed;\n  top: 62px; left: 0; right: 0;\n  background: rgba(5,5,5,0.98); backdrop-filter: blur(16px);\n  z-index: 99; padding: 16px 0 24px;\n  border-bottom: 1px solid var(--border);\n  transform: translateY(-10px); opacity: 0; pointer-events: none;\n  transition: transform 0.25s, opacity 0.25s;\n}\n.mobile-menu.open { transform: translateY(0); opacity: 1; pointer-events: all; }\n.mobile-menu ul { display: flex; flex-direction: column; }\n.mobile-menu a {\n  font-family: var(--font-mono); font-size: 0.95rem;\n  color: var(--text-muted); padding: 14px 28px; display: block;\n  transition: color 0.2s;\n}\n.mobile-menu a:hover { color: var(--accent-light); }\n\n/* Lang toggle */\n.lang-toggle {\n  font-family: var(--font-mono); font-size: 0.72rem; font-weight: 700;\n  letter-spacing: 0.08em;\n  background: transparent;\n  color: var(--accent-light);\n  border: 1px solid var(--accent-border);\n  border-radius: 6px;\n  padding: 4px 10px;\n  cursor: pointer;\n  transition: background 0.2s, color 0.2s, box-shadow 0.2s;\n  flex-shrink: 0;\n}\n.lang-toggle:hover {\n  background: var(--accent-dim);\n  box-shadow: var(--glow-sm);\n}\n\n/* Lang toggle — amber pulse state (page is in EN, PT available) */\n@keyframes pulse-amber {\n  0%, 100% { box-shadow: 0 0 0 0 rgba(251,191,36,0); border-color: rgba(251,191,36,0.5); }\n  50%       { box-shadow: 0 0 0 5px rgba(251,191,36,0.15), 0 0 20px rgba(251,191,36,0.55); border-color: var(--amber); }\n}\n.lang-toggle.pt-available {\n  color: var(--amber);\n  border-color: rgba(251,191,36,0.5);\n  animation: pulse-amber 2.2s ease-in-out infinite;\n}\n.lang-toggle.pt-available:hover {\n  background: var(--amber-dim);\n  box-shadow: 0 0 24px rgba(251,191,36,0.45);\n}\n\n/* Lang hint tooltip */\n.lang-hint {\n  position: fixed;\n  top: 62px;\n  right: 16px;\n  z-index: 998;\n  background: rgba(8,8,8,0.97);\n  border: 1px solid var(--amber);\n  border-radius: 10px;\n  padding: 10px 14px 10px 12px;\n  font-family: var(--font-sans);\n  font-size: 0.74rem;\n  line-height: 1.55;\n  color: var(--text-muted);\n  max-width: 218px;\n  box-shadow: 0 0 20px rgba(251,191,36,0.18), 0 4px 18px rgba(0,0,0,0.6);\n  cursor: pointer;\n  transition: opacity 0.45s ease, transform 0.45s ease;\n  animation: hint-in 0.5s ease 0.8s both;\n}\n@keyframes hint-in {\n  from { opacity: 0; transform: translateY(-6px); }\n  to   { opacity: 1; transform: translateY(0); }\n}\n.lang-hint::before {\n  content: '';\n  position: absolute;\n  top: -7px;\n  right: 28px;\n  width: 12px;\n  height: 12px;\n  background: rgba(8,8,8,0.97);\n  border-top: 1px solid var(--amber);\n  border-left: 1px solid var(--amber);\n  transform: rotate(45deg);\n}\n.lang-hint strong { color: var(--amber); font-weight: 600; }\n.lang-hint.hidden { opacity: 0; transform: translateY(-8px); pointer-events: none; }\n\n/* ============================================================\n   HERO\n   ============================================================ */\n#hero {\n  min-height: 100vh;\n  display: flex; align-items: center;\n  position: relative;\n  padding: 100px 24px 60px;\n  overflow: hidden;\n}\n.hero-bg {\n  position: absolute; inset: 0;\n  background:\n    radial-gradient(ellipse 55% 55% at 15% 15%, rgba(58,12,163,0.12) 0%, transparent 60%),\n    radial-gradient(ellipse 40% 40% at 75% 75%, rgba(109,40,217,0.08) 0%, transparent 60%),\n    radial-gradient(ellipse 30% 30% at 85% 15%, rgba(167,139,250,0.05) 0%, transparent 60%);\n  pointer-events: none;\n}\n.hero-bg::after {\n  content: '';\n  position: absolute; inset: 0;\n  background-image:\n    linear-gradient(rgba(109,40,217,0.06) 1px, transparent 1px),\n    linear-gradient(90deg, rgba(109,40,217,0.06) 1px, transparent 1px);\n  background-size: 60px 60px;\n  mask-image: radial-gradient(ellipse 80% 80% at 30% 30%, black 0%, transparent 65%);\n}\n.hero-content {\n  max-width: 1080px; margin: 0 auto; width: 100%;\n  position: relative; z-index: 1;\n}\n.hero-pre {\n  font-family: var(--font-mono); font-size: 0.85rem;\n  color: var(--accent-light); margin-bottom: 16px; letter-spacing: 1px;\n}\n.claude-blink { animation: blink 1s step-end infinite; margin-right: 6px; }\n@keyframes blink { 0%,100%{opacity:1} 50%{opacity:0} }\n\n.hero-name {\n  font-size: clamp(3.5rem, 10vw, 7rem);\n  font-weight: 800; line-height: 0.95;\n  letter-spacing: -4px; color: var(--text); margin-bottom: 20px;\n}\n.hero-name span {\n  background: linear-gradient(135deg, var(--accent-light) 0%, var(--teal) 100%);\n  -webkit-background-clip: text;\n  -webkit-text-fill-color: transparent;\n  background-clip: text;\n}\n.hero-role {\n  font-family: var(--font-mono); font-size: clamp(0.8rem, 1.8vw, 0.95rem);\n  color: var(--text-muted); margin-bottom: 20px; letter-spacing: 0.5px;\n}\n.hero-sub {\n  font-size: 1rem; color: var(--text-muted);\n  max-width: 500px; margin-bottom: 40px; line-height: 1.85;\n}\n.hero-actions {\n  display: flex; flex-wrap: wrap; gap: 12px; margin-bottom: 56px;\n}\n\n/* Buttons */\n.btn-primary {\n  display: inline-flex; align-items: center; gap: 8px;\n  background: var(--accent);\n  color: #fff; font-weight: 600; font-size: 0.95rem;\n  padding: 12px 24px; border-radius: var(--radius);\n  transition: transform 0.2s, box-shadow 0.2s, background 0.2s;\n  border: 1px solid rgba(109,40,217,0.5);\n}\n.btn-primary:hover {\n  transform: translateY(-2px);\n  box-shadow: var(--glow-md);\n  background: var(--accent-mid);\n}\n.btn-primary.large { padding: 14px 32px; font-size: 1rem; }\n.btn-ghost {\n  display: inline-flex; align-items: center; gap: 8px;\n  background: transparent; color: var(--text-muted); font-weight: 500; font-size: 0.95rem;\n  padding: 12px 20px; border-radius: var(--radius);\n  border: 1px solid var(--border-2);\n  transition: color 0.2s, border-color 0.2s, background 0.2s;\n}\n.btn-ghost:hover { color: var(--text); border-color: rgba(167,139,250,0.3); background: var(--accent-dim); }\n\n/* Stats */\n.hero-stats { display: flex; align-items: center; gap: 24px; }\n.stat { text-align: left; }\n.stat-num { font-family: var(--font-mono); font-size: 1.6rem; font-weight: 700; color: var(--text); }\n.stat span { font-family: var(--font-mono); font-size: 1.1rem; color: var(--accent-light); }\n.stat p { font-size: 0.75rem; color: var(--text-muted); margin-top: 2px; }\n.stat-div { width: 1px; height: 40px; background: var(--border-2); }\n.stat-note { font-size: 0.68rem; color: var(--text-dim); font-family: var(--font-mono); margin-top: 2px; }\n\n.hero-scroll {\n  position: absolute; bottom: 32px; left: 50%; transform: translateX(-50%); z-index: 1;\n}\n.hero-scroll a {\n  color: var(--text-dim); font-size: 1.2rem;\n  animation: bounce 2s infinite; display: block;\n}\n@keyframes bounce { 0%,100%{transform:translateY(0)} 50%{transform:translateY(6px)} }\n\n/* ============================================================\n   SECTION COMMONS\n   ============================================================ */\nsection { padding: 100px 0; }\n.section-label {\n  font-family: var(--font-mono); font-size: 0.78rem;\n  color: var(--accent-light); letter-spacing: 1.5px; margin-bottom: 12px;\n}\n.section-title {\n  font-size: clamp(1.8rem, 4vw, 2.6rem);\n  font-weight: 700; letter-spacing: -1px; color: var(--text); margin-bottom: 56px;\n}\n.highlight {\n  background: linear-gradient(135deg, var(--accent-light), var(--teal));\n  -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;\n}\n\n/* ============================================================\n   SOBRE\n   ============================================================ */\n#sobre { background: var(--bg-2); }\n.sobre-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 48px; align-items: start; }\n.sobre-text h2 {\n  font-size: clamp(1.6rem, 3.5vw, 2.2rem); font-weight: 700;\n  letter-spacing: -1px; margin-bottom: 24px; line-height: 1.3;\n}\n.sobre-text p { color: var(--text-muted); margin-bottom: 16px; font-size: 0.97rem; }\n.sobre-text strong { color: var(--text); font-weight: 600; }\n.sobre-text em { color: var(--accent-light); font-style: normal; }\n.sobre-badges { display: flex; flex-wrap: wrap; gap: 10px; margin-top: 28px; }\n.sobre-badges span {\n  display: inline-flex; align-items: center; gap: 6px;\n  font-size: 0.8rem; font-family: var(--font-mono);\n  color: var(--text-muted); background: var(--bg-3);\n  border: 1px solid var(--border); padding: 6px 14px; border-radius: 999px;\n}\n.sobre-badges i { color: var(--accent-light); font-size: 0.72rem; }\n\n.sobre-card {\n  background: var(--bg-card); border: 1px solid var(--border);\n  border-radius: var(--radius-lg); padding: 28px; position: relative;\n}\n.sobre-card::before {\n  content: ''; position: absolute; top: 0; left: 32px; right: 32px; height: 1px;\n  background: linear-gradient(90deg, transparent, var(--accent-mid), transparent);\n}\n.card-tag { font-family: var(--font-mono); font-size: 0.72rem; color: var(--accent-light); letter-spacing: 1px; margin-bottom: 16px; }\n.sobre-card blockquote {\n  font-size: 0.88rem; color: var(--text-muted); line-height: 1.8;\n  border-left: 2px solid var(--accent); padding-left: 16px;\n  margin-bottom: 12px; font-style: italic;\n}\n.quote-author { font-size: 0.72rem; color: var(--text-dim); margin-bottom: 24px; font-family: var(--font-mono); }\n.card-list { display: flex; flex-direction: column; gap: 10px; }\n.card-item { display: flex; align-items: center; gap: 10px; font-size: 0.88rem; color: var(--text-muted); }\n.card-item i { color: var(--accent-light); font-size: 1rem; flex-shrink: 0; }\n\n/* ============================================================\n   EXPERIÊNCIA\n   ============================================================ */\n.timeline { position: relative; padding-left: 32px; }\n.timeline::before {\n  content: ''; position: absolute; left: 7px; top: 0; bottom: 0; width: 2px;\n  background: linear-gradient(to bottom, var(--accent), var(--teal), transparent); opacity: 0.3;\n}\n.timeline-item { position: relative; margin-bottom: 48px; }\n.timeline-dot {\n  position: absolute; left: -28px; top: 6px; width: 14px; height: 14px;\n  border-radius: 50%; border: 2px solid var(--bg-3); background: var(--text-dim);\n}\n.timeline-dot.active { background: var(--accent-mid); box-shadow: 0 0 12px var(--accent-glow); }\n.timeline-dot.highlight-dot { background: var(--amber); box-shadow: 0 0 12px rgba(251,191,36,0.4); }\n\n.timeline-content {\n  background: var(--bg-card); border: 1px solid var(--border);\n  border-radius: var(--radius); padding: 24px;\n  transition: border-color 0.2s, box-shadow 0.2s;\n}\n.timeline-content:hover { border-color: var(--accent-border); box-shadow: var(--glow-sm); }\n.highlight-content { border-color: rgba(251,191,36,0.15); }\n.highlight-content:hover { border-color: rgba(251,191,36,0.35); box-shadow: 0 0 24px rgba(251,191,36,0.12); }\n\n.timeline-header { display: flex; align-items: flex-start; justify-content: space-between; gap: 12px; margin-bottom: 12px; }\n.timeline-header h3 { font-size: 1.05rem; font-weight: 600; color: var(--text); margin-bottom: 4px; }\n.timeline-org { font-size: 0.82rem; color: var(--text-muted); display: flex; align-items: center; gap: 6px; }\n.timeline-badge {\n  font-family: var(--font-mono); font-size: 0.72rem;\n  padding: 4px 10px; border-radius: 6px;\n  border: 1px solid var(--border); color: var(--text-dim); white-space: nowrap; flex-shrink: 0;\n}\n.timeline-badge.current { border-color: var(--accent-border); color: var(--accent-light); background: var(--accent-dim); }\n.timeline-badge.special { border-color: rgba(251,191,36,0.4); color: var(--amber); background: var(--amber-dim); }\n\n.timeline-content > p { font-size: 0.9rem; color: var(--text-muted); margin-bottom: 16px; }\n.timeline-content strong { color: var(--text); }\n.timeline-tags { display: flex; flex-wrap: wrap; gap: 8px; }\n.timeline-tags span {\n  font-family: var(--font-mono); font-size: 0.72rem;\n  color: var(--text-dim); background: var(--bg-3); padding: 4px 10px; border-radius: 4px;\n}\n\n/* ============================================================\n   SKILLS\n   ============================================================ */\n#skills { background: var(--bg-2); }\n.skills-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 20px; }\n.skill-group {\n  background: var(--bg-card); border: 1px solid var(--border);\n  border-radius: var(--radius); padding: 24px;\n  transition: border-color 0.2s, box-shadow 0.2s;\n}\n.skill-group:hover { border-color: var(--accent-border); box-shadow: var(--glow-sm); }\n.skill-group h3 {\n  display: flex; align-items: center; gap: 10px;\n  font-size: 0.9rem; font-weight: 600; color: var(--text);\n  margin-bottom: 16px; padding-bottom: 12px; border-bottom: 1px solid var(--border);\n}\n.skill-group h3 i { font-size: 1.1rem; color: var(--accent-light); }\n.skill-pills { display: flex; flex-wrap: wrap; gap: 8px; }\n.pill { font-family: var(--font-mono); font-size: 0.75rem; padding: 5px 12px; border-radius: 6px; font-weight: 500; }\n.pill-primary { background: var(--accent-dim); color: var(--accent-light); border: 1px solid var(--accent-border); }\n.pill-blue    { background: rgba(99,179,237,0.08); color: #63b3ed; border: 1px solid rgba(99,179,237,0.15); }\n.pill-teal    { background: var(--teal-dim); color: var(--teal); border: 1px solid rgba(45,212,191,0.18); }\n.pill-purple  { background: rgba(167,139,250,0.1); color: var(--accent-light); border: 1px solid rgba(167,139,250,0.2); }\n.pill-amber   { background: var(--amber-dim); color: var(--amber); border: 1px solid rgba(251,191,36,0.18); }\n\n/* ============================================================\n   PROJETOS\n   ============================================================ */\n.projects-featured-row {\n  display: grid;\n  grid-template-columns: 2fr 1fr;\n  gap: 20px;\n  margin-bottom: 20px;\n}\n.projects-main-grid {\n  display: grid;\n  grid-template-columns: repeat(3, 1fr);\n  gap: 20px;\n}\n\n.project-card {\n  background: var(--bg-card); border: 1px solid var(--border);\n  border-radius: var(--radius-lg); padding: 28px;\n  display: flex; flex-direction: column;\n  transition: transform 0.25s, border-color 0.25s, box-shadow 0.25s;\n}\n.project-card:hover {\n  transform: translateY(-4px);\n  border-color: var(--accent-border);\n  box-shadow: var(--glow-sm);\n}\n.project-card.featured {\n  background: linear-gradient(135deg, var(--bg-card) 0%, rgba(58,12,163,0.08) 100%);\n  border-color: var(--accent-border);\n}\n.project-card.featured:hover { border-color: rgba(109,40,217,0.6); box-shadow: var(--glow-md); }\n.project-card.featured-half {\n  background: linear-gradient(135deg, var(--bg-card), rgba(167,139,250,0.06));\n  border-color: rgba(167,139,250,0.2);\n}\n.project-card.featured-half:hover { border-color: rgba(167,139,250,0.45); box-shadow: var(--glow-sm); }\n\n.project-card-top { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px; }\n.project-icon-wrap {\n  width: 44px; height: 44px;\n  background: var(--accent-dim); border: 1px solid var(--accent-border);\n  border-radius: 10px; display: flex; align-items: center; justify-content: center;\n}\n.project-icon-wrap i { font-size: 1.2rem; color: var(--accent-light); }\n.project-icon-wrap.purple { background: rgba(167,139,250,0.1); border-color: rgba(167,139,250,0.2); }\n.project-icon-wrap.purple i { color: var(--accent-light); }\n.project-icon-wrap.teal   { background: var(--teal-dim); border-color: rgba(45,212,191,0.2); }\n.project-icon-wrap.teal i  { color: var(--teal); }\n.project-icon-wrap.amber  { background: var(--amber-dim); border-color: rgba(251,191,36,0.2); }\n.project-icon-wrap.amber i { color: var(--amber); }\n\n.project-links-wrap { display: flex; gap: 8px; align-items: center; }\n.project-links-wrap a { font-size: 1.2rem; color: var(--text-dim); transition: color 0.2s; }\n.project-links-wrap a:hover { color: var(--accent-light); }\n.lock-badge {\n  font-size: 0.75rem; color: var(--text-dim); font-family: var(--font-mono);\n  padding: 4px 10px; background: var(--bg-3); border-radius: 6px;\n  display: flex; align-items: center; gap: 5px; border: 1px solid var(--border);\n}\n\n.project-label {\n  font-family: var(--font-mono); font-size: 0.7rem;\n  color: var(--accent-light); letter-spacing: 1px; margin-bottom: 8px; display: block;\n}\n.project-card h3 { font-size: 1.1rem; font-weight: 700; color: var(--text); margin-bottom: 10px; letter-spacing: -0.3px; }\n.project-card p { font-size: 0.87rem; color: var(--text-muted); flex-grow: 1; margin-bottom: 16px; line-height: 1.8; }\n.project-card strong { color: var(--accent-light); font-weight: 600; }\n\n.project-tech { display: flex; flex-wrap: wrap; gap: 7px; margin-top: auto; }\n.project-tech span {\n  font-family: var(--font-mono); font-size: 0.7rem;\n  color: var(--text-dim); background: var(--bg-3);\n  border: 1px solid var(--border); padding: 4px 10px; border-radius: 4px;\n  transition: color 0.2s, border-color 0.2s;\n}\n.project-card:hover .project-tech span { color: var(--text-muted); border-color: var(--accent-border); }\n\n/* Governance / Ethics badge */\n.badge-governance {\n  display: inline-flex; align-items: center; gap: 5px;\n  font-family: var(--font-mono); font-size: 0.68rem;\n  color: var(--teal); background: var(--teal-dim);\n  border: 1px solid rgba(45,212,191,0.2); padding: 4px 10px; border-radius: 4px;\n}\n\n/* Narrative: Desafio › Solução › Impacto */\n.narrative { margin: 10px 0 6px; }\n.narrative p { font-size: 0.88rem; color: var(--text-muted); margin-bottom: 8px; }\n.narrative-tag {\n  display: inline-block;\n  font-family: var(--font-mono); font-size: 0.68rem; font-weight: 700;\n  letter-spacing: 0.06em; text-transform: uppercase;\n  color: var(--accent-light); background: var(--accent-dim);\n  border: 1px solid var(--accent-border);\n  border-radius: 4px; padding: 1px 7px; margin-right: 6px;\n  vertical-align: middle;\n}\n\n/* pill-highlight — Playwright, K6, Grafana, Prometheus */\n.pill-highlight {\n  border-color: var(--accent-mid) !important;\n  box-shadow: 0 0 8px rgba(109,40,217,0.25);\n}\n.pill-teal.pill-highlight {\n  border-color: var(--teal) !important;\n  box-shadow: 0 0 8px rgba(45,212,191,0.2);\n}\n\n/* sobre-note (7º Semestre · Cloud Practitioner) */\n.sobre-note { font-size: 0.82rem !important; color: var(--text-dim) !important; margin-top: 4px !important; }\n.sobre-note em { color: var(--text-dim) !important; font-style: italic !important; }\n\n/* Metric callout */\n.project-metric {\n  margin: 10px 0 14px;\n  padding: 10px 14px;\n  background: rgba(58,12,163,0.1);\n  border-left: 2px solid var(--accent-mid);\n  border-radius: 0 8px 8px 0;\n  font-size: 0.82rem;\n  color: var(--accent-light);\n  font-family: var(--font-mono);\n}\n\n/* ============================================================\n   TRIFECTA\n   ============================================================ */\n#trifecta {\n  background: var(--bg-3);\n  padding: 72px 0;\n  border-top: 1px solid var(--border);\n  border-bottom: 1px solid var(--border);\n}\n.trifecta-inner {\n  display: grid;\n  grid-template-columns: 1fr 1.5fr;\n  gap: 56px;\n  align-items: center;\n}\n.trifecta-code-block {\n  font-family: var(--font-mono);\n  font-size: 0.82rem;\n  line-height: 2.1;\n  color: var(--text-muted);\n  background: var(--bg-card);\n  border: 1px solid var(--border);\n  border-radius: var(--radius);\n  padding: 24px 28px;\n  position: relative;\n  overflow: hidden;\n  white-space: nowrap;\n}\n.trifecta-code-block::before {\n  content: '';\n  position: absolute;\n  top: 0; left: 0; right: 0; height: 2px;\n  background: linear-gradient(90deg, var(--accent), var(--accent-light), var(--teal));\n}\n.tc-comment { color: var(--text-dim); font-style: italic; }\n.tc-keyword  { color: var(--pink); }\n.tc-fn       { color: var(--accent-light); }\n.tc-op       { color: var(--text-muted); }\n.tc-key      { color: var(--teal); }\n.tc-str      { color: var(--amber); }\n\n.trifecta-cards {\n  display: flex;\n  align-items: stretch;\n  gap: 0;\n}\n.trifecta-card {\n  flex: 1;\n  background: var(--bg-card);\n  border: 1px solid var(--border);\n  border-radius: var(--radius);\n  padding: 24px 16px;\n  text-align: center;\n  transition: border-color 0.2s, box-shadow 0.2s;\n}\n.trifecta-card:hover {\n  border-color: var(--accent-border);\n  box-shadow: var(--glow-sm);\n}\n.trifecta-card.mid {\n  border-color: var(--accent-border);\n  background: linear-gradient(160deg, var(--bg-card) 0%, rgba(58,12,163,0.12) 100%);\n  box-shadow: var(--glow-sm);\n  transform: scale(1.04);\n  z-index: 1;\n}\n.trifecta-card i {\n  font-size: 1.6rem;\n  color: var(--accent-light);\n  display: block;\n  margin-bottom: 10px;\n}\n.trifecta-card h3 {\n  font-size: 0.84rem;\n  font-weight: 700;\n  color: var(--text);\n  margin-bottom: 8px;\n}\n.trifecta-card p {\n  font-size: 0.76rem;\n  color: var(--text-muted);\n  line-height: 1.7;\n}\n.trifecta-x {\n  font-family: var(--font-mono);\n  font-size: 1.1rem;\n  font-weight: 700;\n  color: var(--accent-mid);\n  padding: 0 8px;\n  flex-shrink: 0;\n  display: flex;\n  align-items: center;\n}\n\n/* ── Projects Pillars legend ── */\n.projects-pillars {\n  display: grid;\n  grid-template-columns: repeat(4, 1fr);\n  gap: 0;\n  margin-bottom: 32px;\n  background: var(--bg-card);\n  border: 1px solid var(--border);\n  border-radius: var(--radius);\n  overflow: hidden;\n}\n.pp-item {\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  text-align: center;\n  gap: 4px;\n  padding: 18px 12px;\n  border-right: 1px solid var(--border);\n  transition: background 0.2s;\n}\n.pp-item:last-child { border-right: none; }\n.pp-item:hover { background: rgba(109,40,217,0.06); }\n.pp-num {\n  font-family: var(--font-mono);\n  font-size: 1rem;\n  font-weight: 700;\n  color: var(--accent-light);\n}\n.pp-name {\n  font-size: 0.8rem;\n  font-weight: 600;\n  color: var(--text);\n}\n.pp-desc {\n  font-size: 0.7rem;\n  color: var(--text-muted);\n  line-height: 1.5;\n}\n\n/* ── Pillar tag on project cards ── */\n.pillar-tag {\n  display: inline-block;\n  font-family: var(--font-mono);\n  font-size: 0.64rem;\n  font-weight: 700;\n  letter-spacing: 0.08em;\n  text-transform: uppercase;\n  color: var(--teal);\n  background: var(--teal-dim);\n  border: 1px solid rgba(45,212,191,0.2);\n  border-radius: 4px;\n  padding: 2px 8px;\n  margin-bottom: 8px;\n  display: block;\n}\n\n/* ============================================================\n   CTA PRO\n   ============================================================ */\n#cta-pro {\n  background: var(--bg-2);\n}\n.cta-pro-inner {\n  max-width: 800px;\n  margin: 0 auto;\n  text-align: center;\n}\n.cta-pro-inner h2 {\n  font-size: clamp(1.8rem, 4vw, 2.6rem);\n  font-weight: 700;\n  letter-spacing: -1px;\n  color: var(--text);\n  margin-bottom: 40px;\n}\n.cta-pro-grid {\n  display: grid;\n  grid-template-columns: 1fr 1fr;\n  gap: 16px;\n  margin-bottom: 40px;\n  text-align: left;\n}\n.cta-pro-item {\n  display: flex;\n  gap: 14px;\n  align-items: flex-start;\n  background: var(--bg-card);\n  border: 1px solid var(--border);\n  border-radius: var(--radius);\n  padding: 20px;\n  transition: border-color 0.2s, box-shadow 0.2s;\n}\n.cta-pro-item:hover {\n  border-color: var(--accent-border);\n  box-shadow: var(--glow-sm);\n}\n.cta-pro-item > i {\n  font-size: 1.2rem;\n  color: var(--accent-light);\n  flex-shrink: 0;\n  margin-top: 2px;\n}\n.cta-pro-item div {\n  display: flex;\n  flex-direction: column;\n  gap: 5px;\n}\n.cta-pro-item strong {\n  font-size: 0.9rem;\n  font-weight: 600;\n  color: var(--text);\n}\n.cta-pro-item span {\n  font-size: 0.82rem;\n  color: var(--text-muted);\n  line-height: 1.7;\n}\n.cta-pro-actions {\n  display: flex;\n  gap: 12px;\n  justify-content: center;\n  flex-wrap: wrap;\n}\n\n/* ============================================================\n   CONQUISTAS\n   ============================================================ */\n.conquistas-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }\n.conquista-card {\n  background: var(--bg-card); border: 1px solid var(--border);\n  border-radius: var(--radius-lg); padding: 24px; display: flex; gap: 20px;\n  transition: border-color 0.2s, box-shadow 0.2s;\n}\n.conquista-card:hover { border-color: var(--accent-border); box-shadow: var(--glow-sm); }\n.conquista-card.main-conquista {\n  grid-column: span 2;\n  background: linear-gradient(135deg, var(--bg-card), rgba(251,191,36,0.04));\n  border-color: rgba(251,191,36,0.2); align-items: center;\n}\n.conquista-card.main-conquista:hover { border-color: rgba(251,191,36,0.4); box-shadow: 0 0 32px rgba(251,191,36,0.1); }\n.conquista-icon { font-size: 2.5rem; color: var(--amber); flex-shrink: 0; text-shadow: 0 0 20px rgba(251,191,36,0.35); }\n.conquista-icon.sm { font-size: 1.8rem; }\n.conquista-tag { font-family: var(--font-mono); font-size: 0.72rem; color: var(--amber); letter-spacing: 1px; display: block; margin-bottom: 8px; }\n.conquista-body h3 { font-size: 1.05rem; font-weight: 700; color: var(--text); margin-bottom: 8px; }\n.conquista-body p { font-size: 0.88rem; color: var(--text-muted); line-height: 1.75; }\n\n/* ============================================================\n   CONTATO\n   ============================================================ */\n#contato {\n  text-align: center;\n  background:\n    radial-gradient(ellipse 50% 60% at 50% 100%, rgba(58,12,163,0.10) 0%, transparent 65%),\n    var(--bg);\n}\n.contato-inner { max-width: 560px; margin: 0 auto; }\n.contato-inner h2 { font-size: clamp(2rem, 5vw, 3rem); font-weight: 800; letter-spacing: -1.5px; margin-bottom: 16px; }\n.contato-inner > p { color: var(--text-muted); margin-bottom: 40px; font-size: 1rem; }\n.contato-links { display: flex; flex-direction: column; gap: 12px; margin-bottom: 36px; text-align: left; }\n.contato-item {\n  display: flex; align-items: center; gap: 16px;\n  background: var(--bg-card); border: 1px solid var(--border);\n  border-radius: var(--radius); padding: 16px 20px;\n  transition: border-color 0.2s, transform 0.2s, box-shadow 0.2s;\n}\n.contato-item:hover { border-color: var(--accent-border); transform: translateX(4px); box-shadow: var(--glow-sm); }\n.contato-item i { font-size: 1.3rem; color: var(--accent-light); flex-shrink: 0; }\n.contato-item span { font-weight: 600; font-size: 0.95rem; display: block; }\n.contato-item small { font-family: var(--font-mono); font-size: 0.78rem; color: var(--text-muted); }\n\n/* ============================================================\n   FOOTER\n   ============================================================ */\nfooter { padding: 28px 0; border-top: 1px solid var(--border); }\n.footer-inner {\n  display: flex; align-items: center; justify-content: space-between;\n  flex-wrap: wrap; gap: 12px; font-size: 0.78rem; color: var(--text-dim);\n}\n.footer-logo { font-family: var(--font-mono); font-size: 1rem; font-weight: 700; color: var(--text-muted); }\n.footer-made { font-family: var(--font-mono); font-size: 0.72rem; }\n\n/* ============================================================\n   RESPONSIVE\n   ============================================================ */\n@media (max-width: 900px) {\n  .projects-featured-row { grid-template-columns: 1fr; }\n  .projects-main-grid    { grid-template-columns: repeat(2, 1fr); }\n  .trifecta-inner        { grid-template-columns: 1fr; gap: 32px; }\n  .trifecta-code-block   { white-space: normal; }\n  .cta-pro-grid          { grid-template-columns: 1fr; }\n  .projects-pillars      { grid-template-columns: repeat(2, 1fr); }\n  .pp-item:nth-child(2)  { border-right: none; }\n  .pp-item:nth-child(3)  { border-right: none; }\n  .pp-item:nth-child(1), .pp-item:nth-child(2) { border-bottom: 1px solid var(--border); }\n}\n@media (max-width: 768px) {\n  .nav-links { display: none; }\n  .nav-toggle { display: flex; }\n  .mobile-menu { display: block; }\n  #hero { padding: 90px 24px 80px; }\n  .hero-stats { gap: 16px; }\n  .stat-num { font-size: 1.3rem; }\n  .sobre-grid { grid-template-columns: 1fr; gap: 32px; }\n  .conquistas-grid { grid-template-columns: 1fr; }\n  .conquista-card.main-conquista { grid-column: span 1; flex-direction: column; }\n  .skills-grid { grid-template-columns: 1fr; }\n  .timeline { padding-left: 24px; }\n  .timeline-dot { left: -22px; }\n  .footer-inner { flex-direction: column; text-align: center; }\n}\n@media (max-width: 576px) {\n  section { padding: 72px 0; }\n  .projects-main-grid { grid-template-columns: 1fr; }\n  .hero-name { letter-spacing: -2px; }\n  .hero-actions { flex-direction: column; }\n  .hero-actions a { text-align: center; justify-content: center; }\n  .hero-stats { flex-wrap: wrap; }\n  .stat-div { display: none; }\n  .timeline-header { flex-direction: column; align-items: flex-start; }\n  .trifecta-cards { flex-direction: column; }\n  .trifecta-card.mid { transform: none; }\n  .trifecta-x { padding: 4px 0; justify-content: center; }\n  .projects-pillars { grid-template-columns: 1fr; }\n  .pp-item { border-right: none; border-bottom: 1px solid var(--border); }\n  .pp-item:nth-child(1), .pp-item:nth-child(2) { border-bottom: 1px solid var(--border); }\n  .pp-item:last-child { border-bottom: none; }\n  .cta-pro-actions { flex-direction: column; align-items: stretch; }\n  .cta-pro-actions a { text-align: center; justify-content: center; }\n}\n"
