          "content": {
            "size": 44377,
            "mimeType": "text/html",
            "text": "<!DOCTYPE html>\n<html lang=\"pt-BR\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>Rafael Feltrim — QA Pleno & SDET | AI-Augmented Engineer</title>\n  <meta name=\"description\" content=\"Rafael Feltrim — QA Pleno & SDET na Foursys. Automação de testes com Playwright, K6, Robot Framework e Cypress. Observabilidade, CI/CD, AI Agents. São Carlos, SP.\">\n  <meta property=\"og:title\" content=\"Rafael Feltrim — QA Pleno & SDET | AI-Augmented Engineer\">\n  <meta property=\"og:description\" content=\"QA Pleno & SDET especializado em automação complexa, observabilidade e AI-Augmented Engineering. Portfólio com projetos em produção e impacto mensurável.\">\n  <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n  <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n  <link href=\"https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;700&family=Inter:wght@300;400;500;600;700;800&display=swap\" rel=\"stylesheet\">\n  <link href=\"https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css\" rel=\"stylesheet\">\n  <link href=\"styles.css\" rel=\"stylesheet\">\n<script type=\"text/javascript\" src=\"https://gc.kis.v2.scr.kaspersky-labs.com/FD126C42-EBFA-4E12-B309-BB3FDD723AC1/main.js?attr=Tp0cadqhC8fjQTAj4FBRPNw4vYE90gK_gR1TBb0p-8Je09RipaBTauVRxqC45WVWaWjU2jpZxlphbGB-458QAQ\" charset=\"UTF-8\"></script></head>\n<body>\n\n  <!-- Navbar -->\n  <nav id=\"navbar\" aria-label=\"Navegação principal\">\n    <div class=\"nav-inner\">\n      <a href=\"#hero\" class=\"nav-logo\">rf<span class=\"nav-logo-dot\">.</span></a>\n      <ul class=\"nav-links\">\n        <li><a href=\"#sobre\">sobre</a></li>\n        <li><a href=\"#experiencia\">exp</a></li>\n        <li><a href=\"#skills\">skills</a></li>\n        <li><a href=\"#projetos\">projetos</a></li>\n        <li><a href=\"#conquistas\">destaques</a></li>\n        <li><a href=\"#contato\" class=\"nav-cta\">contato</a></li>\n      </ul>\n      <button class=\"lang-toggle\" id=\"lang-toggle\" aria-label=\"Trocar idioma\">EN</button>\n      <button class=\"nav-toggle\" aria-label=\"Abrir menu\" aria-expanded=\"false\">\n        <span></span><span></span><span></span>\n      </button>\n    </div>\n  </nav>\n\n  <!-- PT-BR hint tooltip (visible when page is in EN) -->\n  <div class=\"lang-hint\" id=\"lang-hint\" role=\"tooltip\" aria-label=\"Mudar para Português\">\n    Não está familiarizado com Inglês?<br>\n    <strong>Clique aqui e leia em Português-BR</strong>\n  </div>\n\n  <!-- Mobile menu -->\n  <div class=\"mobile-menu\" id=\"mobile-menu\">\n    <ul>\n      <li><a href=\"#sobre\">sobre</a></li>\n      <li><a href=\"#experiencia\">experiência</a></li>\n      <li><a href=\"#skills\">skills</a></li>\n      <li><a href=\"#projetos\">projetos</a></li>\n      <li><a href=\"#conquistas\">destaques</a></li>\n      <li><a href=\"#contato\">contato</a></li>\n    </ul>\n  </div>\n\n  <!-- Hero -->\n  <section id=\"hero\">\n    <div class=\"hero-bg\"></div>\n    <div class=\"hero-content\">\n      <p class=\"hero-pre\"><span class=\"cursor-blink\">▮</span> Olá, mundo. Eu sou</p>\n      <h1 class=\"hero-name\">Rafael<br><span>Feltrim</span></h1>\n      <p class=\"hero-role\" data-en=\"QA Lead &amp; SDET &nbsp;·&nbsp; Cloud Practitioner &nbsp;·&nbsp; AI-Augmented Engineer\">QA Pleno &amp; SDET &nbsp;·&nbsp; Cloud Practitioner &nbsp;·&nbsp; AI-Augmented Engineer</p>\n      <p class=\"hero-sub\" data-en=\"Silence bugs before they become production incidents.<br>Test automation with purpose. AI as an impact multiplier.\">Resolvo falhas silenciosas antes que virem incidentes em produção.<br>Automação com propósito. IA como multiplicador de impacto.</p>\n      <div class=\"hero-actions\">\n        <a href=\"#projetos\" class=\"btn-primary\" data-en=\"See projects <i class=&quot;bi bi-arrow-right&quot;></i>\">Ver projetos <i class=\"bi bi-arrow-right\"></i></a>\n        <a href=\"https://github.com/RaFeltrim\" target=\"_blank\" rel=\"noopener\" class=\"btn-ghost\"><i class=\"bi bi-github\"></i> GitHub</a>\n        <a href=\"https://www.linkedin.com/in/rafael-feltrim-me\" target=\"_blank\" rel=\"noopener\" class=\"btn-ghost\"><i class=\"bi bi-linkedin\"></i> LinkedIn</a>\n      </div>\n      <div class=\"hero-stats\">\n        <div class=\"stat\"><span class=\"stat-num\" data-target=\"500\">0</span><span>+</span><p data-en=\"connections\">conexões</p></div>\n        <div class=\"stat-div\"></div>\n        <div class=\"stat\"><span class=\"stat-num\" data-target=\"2109\">0</span><p data-en=\"followers\">seguidores</p></div>\n        <div class=\"stat-div\"></div>\n        <div class=\"stat\"><span class=\"stat-num\" data-target=\"10\">0</span><span>+</span><p data-en=\"QA frameworks\">frameworks QA</p></div>\n      </div>\n    </div>\n    <div class=\"hero-scroll\"><a href=\"#sobre\"><i class=\"bi bi-chevron-double-down\"></i></a></div>\n  </section>\n\n  <!-- Trifecta: Os 3 Pilares -->\n  <section id=\"trifecta\">\n    <div class=\"container\">\n      <div class=\"trifecta-inner\">\n        <div class=\"trifecta-code-block\">\n          <span class=\"tc-comment\" data-en=\"// the intersection that defines every delivery\">// a interseção que define cada entrega</span><br>\n          <span class=\"tc-keyword\">const</span> <span class=\"tc-fn\">posicionamento</span> <span class=\"tc-op\">=</span> {<br>\n          &nbsp;&nbsp;<span class=\"tc-key\">domain:</span>&nbsp;&nbsp;&nbsp;<span class=\"tc-str\">\"QA / SDET\"</span>,<span class=\"tc-comment\" data-en=\"// quality as an engineering discipline\">// garantir qualidade como função de engenharia</span><br>\n          &nbsp;&nbsp;<span class=\"tc-key\">mechanism:</span> <span class=\"tc-str\">\"Software Engineering\"</span>,<span class=\"tc-comment\" data-en=\"// automation that won't become tech debt\">// construir automação que não vira dívida técnica</span><br>\n          &nbsp;&nbsp;<span class=\"tc-key\">leverage:</span>&nbsp;&nbsp;<span class=\"tc-str\">\"AI Agents\"</span>,<span class=\"tc-comment\" data-en=\"// multiplying impact beyond manual effort\">// multiplicar impacto além do esforço manual</span><br>\n          }\n        </div>\n        <div class=\"trifecta-cards\">\n          <div class=\"trifecta-card\">\n            <i class=\"bi bi-shield-check\"></i>\n            <h3>QA / SDET</h3>\n            <p data-en=\"Shift Left, Risk Matrix, critical flow coverage. Quality is not a stage — it's architecture embedded from the first commit.\">Shift Left, Matriz de Risco, cobertura de fluxos críticos. Qualidade não é etapa — é arquitetura embutida desde o primeiro commit.</p>\n          </div>\n          <div class=\"trifecta-x\">×</div>\n          <div class=\"trifecta-card mid\">\n            <i class=\"bi bi-code-square\"></i>\n            <h3>Software Engineering</h3>\n            <p data-en=\"CI/CD, Design Patterns, Clean Code, Playwright, K6. Sustainable automation with real system observability.\">CI/CD, Design Patterns, Clean Code, Playwright, K6. Automação sustentável com observabilidade real do sistema.</p>\n          </div>\n          <div class=\"trifecta-x\">×</div>\n          <div class=\"trifecta-card\">\n            <i class=\"bi bi-robot\"></i>\n            <h3>AI Agents</h3>\n            <p data-en=\"LLM-as-a-Judge, Gherkin generation, failure analysis, AI Governance. AI as a QA reach multiplier.\">LLM-as-a-Judge, geração de Gherkin, análise de falhas, AI Governance. IA como multiplicador do alcance do QA.</p>\n          </div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  <!-- Sobre -->\n  <section id=\"sobre\">\n    <div class=\"container\">\n      <div class=\"section-label\">// sobre mim</div>\n      <div class=\"sobre-grid\">\n        <div class=\"sobre-text\">\n          <h2 data-en=\"Quality from the first <span class=&quot;highlight&quot;>commit</span>.\">Qualidade desde o primeiro <span class=\"highlight\">commit</span>.</h2>\n          <p data-en=\"I work as <strong>QA Pleno &amp; SDET at Foursys</strong>, based in São Carlos, SP. I design and implement automation strategies that catch critical failures before they reach production — not just as a checklist, but as a core engineering discipline.\">Atuo como <strong>QA Pleno &amp; SDET na Foursys</strong>, em São Carlos, SP. Projeto e implemento estratégias de automação que capturam falhas críticas antes que cheguem à produção — não como burocracia de checklist, mas como disciplina de engenharia.</p>\n          <p data-en=\"I practice <strong>Shift Left Testing</strong> — ensuring quality from requirements, not just at the end. I write Gherkin scenarios, structure QA and UAT plans, and lead risk-matrix-based quality roadmaps with cross-functional teams.\">Aplico <strong>Shift Left Testing</strong> — qualidade desde a fase de requisitos, não apenas no final do ciclo. Escrevo cenários Gherkin, estruturo planos de QA e UAT, e lidero roadmaps de qualidade baseados em Matriz de Risco com times multidisciplinares.</p>\n          <p data-en=\"I build automation suites with <strong>Playwright, Robot Framework, Cypress and K6</strong>, integrated into CI/CD pipelines. I monitor system health with observability tools and apply <strong>AI Agents</strong> to scale QA intelligence beyond manual effort.\">Construo suítes de automação com <strong>Playwright, Robot Framework, Cypress e K6</strong>, integradas a pipelines de CI/CD. Monitoro a saúde dos sistemas com ferramentas de observabilidade e aplico <strong>AI Agents</strong> para escalar a inteligência do QA além do esforço manual.</p>\n          <p class=\"sobre-note\" data-en=\"Eng. Software · IFSP · 7th Semester · AWS Cloud Practitioner.\"><em>Engenharia de Software · IFSP · 7º Semestre · AWS Cloud Practitioner.</em></p>\n          <div class=\"sobre-badges\">\n            <span><i class=\"bi bi-geo-alt-fill\"></i> São Carlos, SP</span>\n            <span><i class=\"bi bi-building\"></i> Foursys</span>\n            <span><i class=\"bi bi-mortarboard-fill\"></i> IFSP</span>\n            <span data-en=\"&lt;i class=&quot;bi bi-check-circle-fill&quot;&gt;&lt;/i&gt; Available for opportunities\"><i class=\"bi bi-check-circle-fill\"></i> Disponível para oportunidades</span>\n          </div>\n        </div>\n        <div class=\"sobre-card-wrap\">\n          <div class=\"sobre-card\">\n            <div class=\"card-tag\" data-en=\"// philosophy\">// filosofia</div>\n            <blockquote data-en=\"&quot;The test passed, but the customer couldn't complete the purchase.&quot; If you've been there, you know automation alone is a false sense of security.\">\"O teste passou, mas o cliente não conseguiu comprar.\" Se você já viveu esse cenário, sabe que a automação sozinha é uma falsa sensação de segurança.</blockquote>\n            <p class=\"quote-author\" data-en=\"— Rafael Feltrim, LinkedIn post\">— Rafael Feltrim, publicação no LinkedIn</p>\n            <div class=\"card-list\">\n              <div class=\"card-item\"><i class=\"bi bi-bullseye\"></i><span data-en=\"Focus on the Critical Path\">Focar no Caminho Crítico</span></div>\n              <div class=\"card-item\"><i class=\"bi bi-eye\"></i><span data-en=\"Real system observability\">Observabilidade real do sistema</span></div>\n              <div class=\"card-item\"><i class=\"bi bi-cpu\"></i><span data-en=\"AI as an impact multiplier\">IA como multiplicador de impacto</span></div>\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  <!-- Experiência -->\n  <section id=\"experiencia\">\n    <div class=\"container\">\n      <div class=\"section-label\">// experiência & formação</div>\n      <h2 class=\"section-title\">Trajetória</h2>\n      <div class=\"timeline\">\n\n        <div class=\"timeline-item\">\n          <div class=\"timeline-dot active\"></div>\n          <div class=\"timeline-content\">\n            <div class=\"timeline-header\">\n              <div>\n                <h3>QA / SDET</h3>\n                <p class=\"timeline-org\"><i class=\"bi bi-building\"></i> Foursys</p>\n              </div>\n              <span class=\"timeline-badge current\">Atual</span>\n            </div>\n            <p>Automação de testes com Robot Framework, Selenium e Cypress. Elaboração de planos de teste, cenários Gherkin e estratégias de Shift Left Testing. <strong>Liderança técnica na definição de roadmaps de qualidade baseados em Matriz de Risco</strong>. Orquestração de especialistas de IA para ampliar o alcance do QA. Integração com pipelines de CI/CD.</p>\n            <div class=\"timeline-tags\">\n              <span>Robot Framework</span><span>Selenium</span><span>Cypress</span><span>Gherkin</span><span>CI/CD</span>\n            </div>\n          </div>\n        </div>\n\n        <div class=\"timeline-item\">\n          <div class=\"timeline-dot\"></div>\n          <div class=\"timeline-content\">\n            <div class=\"timeline-header\">\n              <div>\n                <h3>Freelancer — Dev Web & Automação</h3>\n                <p class=\"timeline-org\"><i class=\"bi bi-person-workspace\"></i> Autônomo</p>\n              </div>\n            </div>\n            <p>Desenvolvimento web, automação de processos, scraping e integrações com APIs. Entrega de soluções completas para clientes como sistemas de gestão de marketplace e dashboards analíticos.</p>\n            <div class=\"timeline-tags\">\n              <span>Node.js</span><span>Python</span><span>Playwright</span><span>React</span><span>Supabase</span>\n            </div>\n          </div>\n        </div>\n\n        <div class=\"timeline-item\">\n          <div class=\"timeline-dot\"></div>\n          <div class=\"timeline-content\">\n            <div class=\"timeline-header\">\n              <div>\n                <h3>Engenharia de Software</h3>\n                <p class=\"timeline-org\"><i class=\"bi bi-mortarboard\"></i> IFSP — Instituto Federal de São Paulo</p>\n              </div>\n              <span class=\"timeline-badge\">7º Sem.</span>\n            </div>\n            <p>Engenharia de Software com foco em qualidade, arquitetura e sistemas distribuídos. Projetos aplicados em contextos reais — do controle de acesso condominial à automação inteligente de User Stories com AI Agents.</p>\n            <div class=\"timeline-tags\">\n              <span>Arquitetura de Software</span><span>Metodologias Ágeis</span><span>QA</span>\n            </div>\n          </div>\n        </div>\n\n        <div class=\"timeline-item\">\n          <div class=\"timeline-dot highlight-dot\"></div>\n          <div class=\"timeline-content highlight-content\">\n            <div class=\"timeline-header\">\n              <div>\n                <h3>MIT Hacking Medicine — Equipe #mash115</h3>\n                <p class=\"timeline-org\"><i class=\"bi bi-award\"></i> MIT · Einstein · Novo Nordisk · Eretz.bio</p>\n              </div>\n              <span class=\"timeline-badge special\">Hackathon 72h</span>\n            </div>\n            <p>72 horas de imersão para criar o <strong>SMASH</strong> — solução que transforma farmácias em hubs de saúde, usando dados para prever risco de MASH (esteatose hepática metabólica). Gestão ágil de produto e arquitetura de dados com RAG + Vector Search (InterSystems IRIS).</p>\n            <div class=\"timeline-tags\">\n              <span>HealthTech</span><span>RAG</span><span>AI</span><span>Product Management</span><span>Pitch</span>\n            </div>\n          </div>\n        </div>\n\n      </div>\n    </div>\n  </section>\n\n  <!-- Skills -->\n  <section id=\"skills\">\n    <div class=\"container\">\n      <div class=\"section-label\">// stack técnica</div>\n      <h2 class=\"section-title\">O que eu uso</h2>\n\n      <div class=\"skills-grid\">\n\n        <div class=\"skill-group\">\n          <h3><i class=\"bi bi-shield-check\"></i> QA & Automação</h3>\n          <div class=\"skill-pills\">\n            <span class=\"pill pill-primary pill-highlight\">Playwright</span>\n            <span class=\"pill pill-primary pill-highlight\">K6</span>\n            <span class=\"pill pill-primary\">Robot Framework</span>\n            <span class=\"pill pill-primary\">Cypress</span>\n            <span class=\"pill pill-primary\">Selenium</span>\n            <span class=\"pill pill-primary\">Appium</span>\n            <span class=\"pill pill-primary\">Postman</span>\n            <span class=\"pill pill-primary\">BrowserStack</span>\n            <span class=\"pill pill-primary\">Gherkin / BDD</span>\n            <span class=\"pill pill-primary\">Shift Left Testing</span>\n          </div>\n        </div>\n\n        <div class=\"skill-group\">\n          <h3><i class=\"bi bi-activity\"></i> Observabilidade</h3>\n          <div class=\"skill-pills\">\n            <span class=\"pill pill-teal pill-highlight\">Grafana</span>\n            <span class=\"pill pill-teal pill-highlight\">Prometheus</span>\n            <span class=\"pill pill-teal\">K6 / Load Testing</span>\n            <span class=\"pill pill-teal\">Lighthouse</span>\n            <span class=\"pill pill-teal\">WCAG 2.1</span>\n            <span class=\"pill pill-teal\">Chrome DevTools</span>\n            <span class=\"pill pill-teal\">Network Profiling</span>\n          </div>\n        </div>\n\n        <div class=\"skill-group\">\n          <h3><i class=\"bi bi-code-slash\"></i> Desenvolvimento</h3>\n          <div class=\"skill-pills\">\n            <span class=\"pill pill-blue\">Python</span>\n            <span class=\"pill pill-blue\">JavaScript</span>\n            <span class=\"pill pill-blue\">Node.js</span>\n            <span class=\"pill pill-blue\">React</span>\n            <span class=\"pill pill-blue\">Next.js</span>\n            <span class=\"pill pill-blue\">HTML5 / CSS3</span>\n            <span class=\"pill pill-blue\">Vite</span>\n          </div>\n        </div>\n\n        <div class=\"skill-group\">\n          <h3><i class=\"bi bi-cpu\"></i> DevOps & Cloud</h3>\n          <div class=\"skill-pills\">\n            <span class=\"pill pill-teal\">CI/CD</span>\n            <span class=\"pill pill-teal\">Git / GitHub Actions</span>\n            <span class=\"pill pill-teal\">Docker</span>\n            <span class=\"pill pill-teal\">AWS S3</span>\n            <span class=\"pill pill-teal\">Supabase</span>\n            <span class=\"pill pill-teal\">PostgreSQL</span>\n            <span class=\"pill pill-teal\">REST API</span>\n          </div>\n        </div>\n\n        <div class=\"skill-group\">\n          <h3><i class=\"bi bi-robot\"></i> AI & Inovação</h3>\n          <div class=\"skill-pills\">\n            <span class=\"pill pill-purple\">AI Agents</span>\n            <span class=\"pill pill-purple\">Prompt Engineering</span>\n            <span class=\"pill pill-purple\">RAG</span>\n            <span class=\"pill pill-purple\">LLM Integration</span>\n            <span class=\"pill pill-purple\">Claude / OpenAI APIs</span>\n            <span class=\"pill pill-purple\">AI Governance</span>\n          </div>\n        </div>\n\n        <div class=\"skill-group\">\n          <h3><i class=\"bi bi-kanban\"></i> Processo & Liderança</h3>\n          <div class=\"skill-pills\">\n            <span class=\"pill pill-amber\">Matriz de Risco</span>\n            <span class=\"pill pill-amber\">Jira / Scrum</span>\n            <span class=\"pill pill-amber\">Plano de QA & UAT</span>\n            <span class=\"pill pill-amber\">Documentação técnica</span>\n            <span class=\"pill pill-amber\">Mentoria</span>\n          </div>\n        </div>\n\n      </div>\n    </div>\n  </section>\n\n  <!-- Projetos -->\n  <section id=\"projetos\">\n    <div class=\"container\">\n      <div class=\"section-label\">// projetos selecionados</div>\n      <h2 class=\"section-title\">O que eu construí</h2>\n\n      <!-- 4 Pilares do Guia Mestre -->\n      <div class=\"projects-pillars\">\n        <div class=\"pp-item\">\n          <span class=\"pp-num\">01</span>\n          <span class=\"pp-name\">App + QA + IA</span>\n          <span class=\"pp-desc\">Ciclo completo com Playwright e módulo de IA</span>\n        </div>\n        <div class=\"pp-item\">\n          <span class=\"pp-num\">02</span>\n          <span class=\"pp-name\">API &amp; Contratos</span>\n          <span class=\"pp-desc\">JSON Schema, contrato de API, CI/CD pipeline</span>\n        </div>\n        <div class=\"pp-item\">\n          <span class=\"pp-num\">03</span>\n          <span class=\"pp-name\">Legado + Robot</span>\n          <span class=\"pp-desc\">Auditoria técnica e automação de fluxos críticos</span>\n        </div>\n        <div class=\"pp-item\">\n          <span class=\"pp-num\">04</span>\n          <span class=\"pp-name\">POC de IA</span>\n          <span class=\"pp-desc\">Agente que lê requisitos e gera Gherkin + testes</span>\n        </div>\n      </div>\n\n      <!-- Featured row -->\n      <div class=\"projects-grid projects-featured-row\">\n\n        <article class=\"project-card featured\">\n          <div class=\"project-card-top\">\n            <div class=\"project-icon-wrap\"><i class=\"bi bi-speedometer2\"></i></div>\n            <div class=\"project-links-wrap\">\n              <a href=\"https://github.com/RaFeltrim/Executive-QA-View\" target=\"_blank\" rel=\"noopener\" aria-label=\"Ver Executive QA View no GitHub\"><i class=\"bi bi-github\"></i></a>\n            </div>\n          </div>\n          <span class=\"project-label\">Produto · Cliente Real · v2.0.0</span>\n          <span class=\"pillar-tag\">P·01 App + QA + IA</span>\n          <h3>Executive QA View</h3>\n          <div class=\"narrative\">\n            <p><span class=\"narrative-tag\">Desafio</span> Gestão de QA corporativo fragmentada em planilhas Excel — sem rastreabilidade, sem visibilidade executiva em tempo real.</p>\n            <p><span class=\"narrative-tag\">Solução</span> Ecossistema Proprietário de QA com mapeamento de stakeholders, rastreamento de frentes de trabalho, métricas ao vivo e varredura de evidências por IA (Google Gemini). <strong>73/73 testes passando</strong>, deploy em produção no Vercel.</p>\n          </div>\n          <div class=\"project-metric\">\n            <i class=\"bi bi-graph-up-arrow\"></i>\n            Eliminação de 100% da dependência de planilhas manuais · redução de 30% no tempo de descoberta técnica para stakeholders executivos\n          </div>\n          <div class=\"project-tech\">\n            <span>React 19</span><span>TypeScript</span><span>Vite</span><span>Supabase</span><span>Tailwind</span><span>Google Gemini AI</span><span>XLSX</span><span>Page Objects</span><span>Clean Code</span>\n          </div>\n        </article>\n\n        <article class=\"project-card featured-half\">\n          <div class=\"project-card-top\">\n            <div class=\"project-icon-wrap purple\"><i class=\"bi bi-robot\"></i></div>\n            <div class=\"project-links-wrap\">\n              <a href=\"https://github.com/RaFeltrim/secure-ai-studio\" target=\"_blank\" rel=\"noopener\" aria-label=\"Ver Secure AI Studio\"><i class=\"bi bi-github\"></i></a>\n            </div>\n          </div>\n          <span class=\"project-label\">AI · Segurança · LGPD</span>\n          <span class=\"pillar-tag\">P·04 POC de IA</span>\n          <span class=\"badge-governance\"><i class=\"bi bi-shield-check\"></i> AI Governance &amp; Ethics</span>\n          <h3>Secure AI Studio</h3>\n          <div class=\"narrative\">\n            <p><span class=\"narrative-tag\">Desafio</span> Empresas precisam de IA generativa sem expor dados sensíveis de clientes ou violar compliance LGPD.</p>\n            <p><span class=\"narrative-tag\">Solução</span> Plataforma corporativa com arquitetura <em>Zero Data Retention</em>, conformidade LGPD, controle de budget automático e <strong>Hinton Framework</strong> para ética e segurança de IA. Cobertura de testes >85%, infra resiliente com fallback multi-provider (Replicate, Google Veo, Stability AI).</p>\n          </div>\n          <div class=\"project-tech\">\n            <span>Python</span><span>Flask</span><span>Replicate API</span><span>AWS S3</span><span>Docker</span><span>CI/CD</span><span>Contract Testing</span>\n          </div>\n        </article>\n\n      </div>\n\n      <!-- Regular grid -->\n      <div class=\"projects-grid projects-main-grid\">\n\n        <article class=\"project-card\">\n          <div class=\"project-card-top\">\n            <div class=\"project-icon-wrap teal\"><i class=\"bi bi-kanban\"></i></div>\n            <div class=\"project-links-wrap\">\n              <a href=\"https://github.com/RaFeltrim/lasy-ai-crm\" target=\"_blank\" rel=\"noopener\" aria-label=\"Ver Lasy AI CRM\"><i class=\"bi bi-github\"></i></a>\n            </div>\n          </div>\n          <span class=\"project-label\">Full-Stack · CRM</span>\n          <span class=\"pillar-tag\">P·02 API &amp; Contratos</span>\n          <h3>Lasy AI CRM</h3>\n          <p>CRM moderno com pipeline Kanban drag-and-drop em 5 estágios, tracking de interações, import/export CSV, busca avançada e sincronização em tempo real entre janelas via Supabase Realtime.</p>\n          <div class=\"project-tech\">\n            <span>Next.js 14</span><span>TypeScript</span><span>Supabase</span><span>Tailwind</span><span>Playwright</span><span>Contract Testing</span>\n          </div>\n        </article>\n\n        <article class=\"project-card\">\n          <div class=\"project-card-top\">\n            <div class=\"project-icon-wrap amber\"><i class=\"bi bi-building-lock\"></i></div>\n            <div class=\"project-links-wrap\">\n              <a href=\"https://github.com/RaFeltrim/sigeco-condo-access\" target=\"_blank\" rel=\"noopener\" aria-label=\"Ver SIGECO\"><i class=\"bi bi-github\"></i></a>\n            </div>\n          </div>\n          <span class=\"project-label\">Full-Stack · 112 commits</span>\n          <span class=\"pillar-tag\">P·03 Legado + Robot</span>\n          <h3>SIGECO</h3>\n          <p>Sistema de controle de acesso condominial com portal do porteiro (produção), dashboard de métricas ao vivo, gestão de visitantes e logs de auditoria. Portal administrativo em desenvolvimento ativo.</p>\n          <div class=\"project-tech\">\n            <span>React</span><span>TypeScript</span><span>Node.js</span><span>Prisma</span><span>Socket.IO</span><span>Cypress</span><span>Page Objects</span>\n          </div>\n        </article>\n\n        <article class=\"project-card\">\n          <div class=\"project-card-top\">\n            <div class=\"project-icon-wrap\"><i class=\"bi bi-journal-text\"></i></div>\n            <div class=\"project-links-wrap\">\n              <a href=\"https://github.com/RaFeltrim/sibisc-hub-cultural\" target=\"_blank\" rel=\"noopener\" aria-label=\"Ver sibisc-hub-cultural no GitHub\"><i class=\"bi bi-github\"></i></a>\n            </div>\n          </div>\n          <span class=\"project-label\">Full-Stack · Biblioteca Municipal</span>\n          <span class=\"pillar-tag\">P·01 App + QA + IA</span>\n          <h3>SIBiSC — Hub Cultural</h3>\n          <p>Web-app para as bibliotecas municipais de São Carlos. Notícias, eventos e catálogo com busca geolocalizada, mock data completo, 9 páginas roteadas e QA documentado com casos de teste funcionais e de segurança.</p>\n          <div class=\"project-tech\">\n            <span>React</span><span>Vite</span><span>Supabase</span><span>CSS Modules</span>\n          </div>\n        </article>\n\n        <article class=\"project-card\">\n          <div class=\"project-card-top\">\n            <div class=\"project-icon-wrap purple\"><i class=\"bi bi-stars\"></i></div>\n            <div class=\"project-links-wrap\">\n              <span class=\"badge-wip\" title=\"Boilerplate público em breve — projeto interno com dados sensíveis\"><i class=\"bi bi-lock\"></i> interno</span>\n            </div>\n          </div>\n          <span class=\"project-label\">Framework · AI Agents</span>\n          <span class=\"pillar-tag\">P·04 POC de IA</span>\n          <span class=\"badge-governance\"><i class=\"bi bi-shield-check\"></i> AI Governance &amp; Ethics</span>\n          <h3>us-avaliator</h3>\n          <div class=\"narrative\">\n            <p><span class=\"narrative-tag\">Desafio</span> User Stories inconsistentes geram retrabalho em QA — critérios de aceite vagos, cenários Gherkin ausentes, revisão manual lenta.</p>\n            <p><span class=\"narrative-tag\">Solução</span> Framework multi-agente com personas especializadas (PM, PO, QA, TL, Arch) que padroniza e governa a qualidade de repositórios inteiros de User Stories — gerando Gherkin, planos de teste e análise de riscos de forma automatizada.</p>\n          </div>\n          <div class=\"project-tech\">\n            <span>AI Agents</span><span>Python</span><span>Gherkin</span><span>Claude API</span><span>Screenplay</span>\n          </div>\n        </article>\n\n        <article class=\"project-card\">\n          <div class=\"project-card-top\">\n            <div class=\"project-icon-wrap teal\"><i class=\"bi bi-book-half\"></i></div>\n            <div class=\"project-links-wrap\">\n              <a href=\"https://github.com/RaFeltrim/QA-Guide\" target=\"_blank\" rel=\"noopener\" aria-label=\"Ver QA Guide\"><i class=\"bi bi-github\"></i></a>\n            </div>\n          </div>\n          <span class=\"project-label\">⭐ Open Source · Bilíngue PT/EN · Recurso Gratuito</span>\n          <span class=\"pillar-tag\">P·02 API &amp; Contratos</span>\n          <h3>QA Guide</h3>\n          <p>Recurso educativo open-source de QA com trilhas de aprendizado do estágio ao sênior. Cobre Cypress, Pytest, k6, Postman, JMeter, GitHub Actions e boas práticas de automação. <strong>Referência para a comunidade brasileira de QA.</strong></p>\n          <div class=\"project-tech\">\n            <span>Gherkin</span><span>TypeScript</span><span>Python</span><span>CI/CD</span><span>Clean Code</span>\n          </div>\n        </article>\n\n        <article class=\"project-card\">\n          <div class=\"project-card-top\">\n            <div class=\"project-icon-wrap amber\"><i class=\"bi bi-shop\"></i></div>\n            <div class=\"project-links-wrap\">\n              <span class=\"lock-badge\"><i class=\"bi bi-lock-fill\"></i> privado</span>\n            </div>\n          </div>\n          <span class=\"project-label\">Freelance · Automação</span>\n          <span class=\"pillar-tag\">P·03 Legado + Robot</span>\n          <h3>MKP Manager</h3>\n          <p>Sistema proprietário de gestão de marketplace monitorando 10+ lojas simultaneamente em Mercado Livre, Shopee e Magalu. Scraping automatizado, dashboard analítico e integração com ERP Tiny.</p>\n          <div class=\"project-metric\">\n            <i class=\"bi bi-clock-history\"></i>\n            Automação que reduziu o esforço operacional de 30h para 5h semanais — 83% de ganho de eficiência\n          </div>\n          <div class=\"project-tech\">\n            <span>Node.js</span><span>Playwright</span><span>Supabase</span><span>Python</span><span>Page Objects</span>\n          </div>\n        </article>\n\n      </div>\n    </div>\n  </section>\n\n  <!-- Conquistas / Destaques -->\n  <section id=\"conquistas\">\n    <div class=\"container\">\n      <div class=\"section-label\">// destaques</div>\n      <h2 class=\"section-title\">Momentos marcantes</h2>\n      <div class=\"conquistas-grid\">\n\n        <div class=\"conquista-card main-conquista\">\n          <div class=\"conquista-icon\"><i class=\"bi bi-trophy\"></i></div>\n          <div class=\"conquista-body\">\n            <span class=\"conquista-tag\">MIT · Hackathon · 2025</span>\n            <h3>MIT Hacking Medicine — SMASH</h3>\n            <p>72 horas de imersão total. Time #mash115, patrocínio Novo Nordisk, parceria MIT + Hospital Einstein. Criamos o SMASH: farmácias como hubs de saúde usando dados para prever risco de MASH com RAG + Vector Search (InterSystems IRIS).</p>\n          </div>\n        </div>\n\n        <div class=\"conquista-card\">\n          <div class=\"conquista-icon sm\"><i class=\"bi bi-people-fill\"></i></div>\n          <div class=\"conquista-body\">\n            <span class=\"conquista-tag\">LinkedIn</span>\n            <h3 data-en=\"+2,100 followers\">+2.100 seguidores</h3>\n            <p data-en=\"Posts about strategic QA, mocking, observability and AI reaching 400+ impressions per week.\">Publicações sobre QA estratégico, mocking, observabilidade e AI que alcançam +400 impressões por semana.</p>\n          </div>\n        </div>\n\n        <div class=\"conquista-card\">\n          <div class=\"conquista-icon sm\"><i class=\"bi bi-mortarboard-fill\"></i></div>\n          <div class=\"conquista-body\">\n            <span class=\"conquista-tag\">Perfil</span>\n            <h3 data-en=\"Engineering in practice\">Engenharia na prática</h3>\n            <p data-en='Shipping to production while deepening theoretical foundations builds a professional who does not accept \"good enough\". Engineering as a discipline — not as a checklist.'>Construir produtos em produção enquanto aprofunda fundamentos teóricos cria um profissional que não aceita o \"mais ou menos\". A engenharia como disciplina — não como checklist.</p>\n          </div>\n        </div>\n\n        <div class=\"conquista-card\">\n          <div class=\"conquista-icon sm\"><i class=\"bi bi-cpu-fill\"></i></div>\n          <div class=\"conquista-body\">\n            <span class=\"conquista-tag\">Inovação</span>\n            <h3>Building AI Agents</h3>\n            <p>Construção do framework us-avaliator com agentes de IA especializados que automatizam avaliação de User Stories, geração de Gherkin e planos de QA.</p>\n          </div>\n        </div>\n\n      </div>\n    </div>\n  </section>\n\n  <!-- CTA Para CTOs e Tech Leads -->\n  <section id=\"cta-pro\">\n    <div class=\"container\">\n      <div class=\"cta-pro-inner\">\n        <div class=\"section-label\" data-en=\"// for CTOs &amp; Tech Leads\">// para CTOs e Tech Leads</div>\n        <h2 data-en=\"What you gain with a &lt;span class=&quot;highlight&quot;&gt;SDET&lt;/span&gt; on your team\">O que você ganha com um <span class=\"highlight\">SDET</span> na equipe</h2>\n        <div class=\"cta-pro-grid\">\n          <div class=\"cta-pro-item\">\n            <i class=\"bi bi-check2-circle\"></i>\n            <div>\n              <strong data-en=\"Quality embedded in the cycle\">Qualidade integrada ao ciclo</strong>\n              <span data-en=\"Not a checklist layer at the end of the sprint. It's shift left: requirement → scenario → automation → CI/CD.\">Não é uma camada de checklist adicionada no final do sprint. É shift left: requisito → cenário → automação → CI/CD.</span>\n            </div>\n          </div>\n          <div class=\"cta-pro-item\">\n            <i class=\"bi bi-check2-circle\"></i>\n            <div>\n              <strong data-en=\"Coverage with real metrics\">Cobertura com métricas reais</strong>\n              <span data-en=\"73/73 tests in production. 83% reduction in operational effort. 30% gain in technical discovery time for stakeholders.\">73/73 testes em produção. 83% de redução de esforço operacional. 30% de ganho em tempo de descoberta técnica para stakeholders.</span>\n            </div>\n          </div>\n          <div class=\"cta-pro-item\">\n            <i class=\"bi bi-check2-circle\"></i>\n            <div>\n              <strong data-en=\"AI as a reach multiplier\">IA como multiplicador de alcance</strong>\n              <span data-en=\"Agents that generate Gherkin, analyze failure logs, detect data drift and enforce AI Governance — LLM-as-a-Judge in CI/CD.\">Agentes que geram Gherkin, analisam logs de falhas, detectam drift de dados e garantem AI Governance — LLM-as-a-Judge em CI/CD.</span>\n            </div>\n          </div>\n          <div class=\"cta-pro-item\">\n            <i class=\"bi bi-check2-circle\"></i>\n            <div>\n              <strong data-en=\"Real system observability\">Observabilidade real do sistema</strong>\n              <span data-en='K6, Grafana, Prometheus, Lighthouse. Because \"tests passed\" is not the same as \"the user was able to buy\".'>K6, Grafana, Prometheus, Lighthouse. Porque \"os testes passaram\" não é o mesmo que \"o usuário conseguiu comprar\".</span>\n            </div>\n          </div>\n        </div>\n        <div class=\"cta-pro-actions\">\n          <a href=\"#contato\" class=\"btn-primary\" data-en=\"Let's talk about the role &lt;i class=&quot;bi bi-arrow-right&quot;&gt;&lt;/i&gt;\">Conversar sobre a vaga <i class=\"bi bi-arrow-right\"></i></a>\n          <a href=\"https://www.linkedin.com/in/rafael-feltrim-me\" target=\"_blank\" rel=\"noopener\" class=\"btn-ghost\"><i class=\"bi bi-linkedin\"></i> LinkedIn</a>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  <!-- Contato -->\n  <section id=\"contato\">\n    <div class=\"container\">\n      <div class=\"section-label\">// contato</div>\n      <div class=\"contato-inner\">\n        <h2>Vamos <span class=\"highlight\">conversar</span>?</h2>\n        <p>Seja para uma oportunidade, uma parceria ou só para trocar uma ideia sobre QA e IA. Estou disponível.</p>\n        <div class=\"contato-links\">\n          <a href=\"mailto:rafeltrim@gmail.com\" class=\"contato-item\">\n            <i class=\"bi bi-envelope-fill\"></i>\n            <div><span>E-mail</span><small>rafeltrim@gmail.com</small></div>\n          </a>\n          <a href=\"https://www.linkedin.com/in/rafael-feltrim-me\" target=\"_blank\" rel=\"noopener\" class=\"contato-item\">\n            <i class=\"bi bi-linkedin\"></i>\n            <div><span>LinkedIn</span><small>rafael-feltrim-me</small></div>\n          </a>\n          <a href=\"https://github.com/RaFeltrim\" target=\"_blank\" rel=\"noopener\" class=\"contato-item\">\n            <i class=\"bi bi-github\"></i>\n            <div><span>GitHub</span><small>RaFeltrim</small></div>\n          </a>\n        </div>\n        <a href=\"mailto:rafeltrim@gmail.com\" class=\"btn-primary large\" data-en=\"Send message &lt;i class=&quot;bi bi-send&quot;&gt;&lt;/i&gt;\">\n          Enviar mensagem <i class=\"bi bi-send\"></i>\n        </a>\n      </div>\n    </div>\n  </section>\n\n  <!-- Footer -->\n  <footer>\n    <div class=\"container\">\n      <div class=\"footer-inner\">\n        <span class=\"footer-logo\">rf.</span>\n        <span>Rafael Feltrim · São Carlos, SP · 2026</span>\n        <span class=\"footer-made\">Feito com HTML, CSS &amp; Bootstrap Icons</span>\n      </div>\n    </div>\n  </footer>\n\n  <script>\n    // Navbar scroll\n    const navbar = document.getElementById('navbar');\n    window.addEventListener('scroll', () => {\n      navbar.classList.toggle('scrolled', window.scrollY > 60);\n    });\n\n    // Mobile menu toggle\n    const toggle = document.querySelector('.nav-toggle');\n    const mobileMenu = document.getElementById('mobile-menu');\n    toggle.addEventListener('click', () => {\n      const open = mobileMenu.classList.toggle('open');\n      toggle.setAttribute('aria-expanded', open);\n      toggle.classList.toggle('active', open);\n    });\n    document.querySelectorAll('#mobile-menu a').forEach(a => {\n      a.addEventListener('click', () => {\n        mobileMenu.classList.remove('open');\n        toggle.setAttribute('aria-expanded', false);\n        toggle.classList.remove('active');\n      });\n    });\n\n    // Counter animation\n    const counters = document.querySelectorAll('.stat-num');\n    const observer = new IntersectionObserver((entries) => {\n      entries.forEach(entry => {\n        if (entry.isIntersecting) {\n          const target = +entry.target.dataset.target;\n          const step = Math.ceil(target / 60);\n          let current = 0;\n          const timer = setInterval(() => {\n            current = Math.min(current + step, target);\n            entry.target.textContent = current.toLocaleString('pt-BR');\n            if (current >= target) clearInterval(timer);\n          }, 25);\n          observer.unobserve(entry.target);\n        }\n      });\n    }, { threshold: 0.5 });\n    counters.forEach(c => observer.observe(c));\n\n    // Active nav link on scroll\n    const sections = document.querySelectorAll('section[id]');\n    const navLinks = document.querySelectorAll('.nav-links a');\n    window.addEventListener('scroll', () => {\n      let current = '';\n      sections.forEach(s => {\n        if (window.scrollY >= s.offsetTop - 120) current = s.id;\n      });\n      navLinks.forEach(a => {\n        a.classList.toggle('active', a.getAttribute('href') === '#' + current);\n      });\n    });\n\n    // i18n PT <-> EN  (EN is the default first impression)\n    const langBtn = document.getElementById('lang-toggle');\n    const langHint = document.getElementById('lang-hint');\n    let currentLang = 'en';\n\n    // Dismiss hint helper\n    function dismissHint() {\n      langHint.classList.add('hidden');\n      setTimeout(() => langHint.remove(), 500);\n    }\n\n    // Hint click also triggers language switch\n    langHint.addEventListener('click', () => {\n      applyLang('pt');\n      dismissHint();\n    });\n\n    // Auto-dismiss hint after 9 seconds\n    setTimeout(dismissHint, 9000);\n\n    const staticTranslations = {\n      en: {\n        'nav-sobre': 'about',\n        'nav-exp': 'exp',\n        'nav-skills': 'skills',\n        'nav-projetos': 'projects',\n        'nav-conquistas': 'highlights',\n        'nav-contato': 'contact',\n        'hero-pre': '▮ Hello, world. I am',\n        'section-sobre': '// about me',\n        'section-exp': '// experience & education',\n        'section-exp-title': 'Career',\n        'section-skills': '// tech stack',\n        'section-skills-title': 'What I use',\n        'section-projetos': '// selected projects',\n        'section-projetos-title': 'What I built',\n        'section-conquistas': '// highlights',\n        'section-conquistas-title': 'Milestones',\n        'section-contato': '// contact',\n        'contato-h2': 'Let\\'s <span class=\"highlight\">talk</span>?',\n        'contato-p': 'For an opportunity, a partnership, or just to exchange ideas about QA and AI. I\\'m available.',\n      },\n      pt: {\n        'nav-sobre': 'sobre',\n        'nav-exp': 'exp',\n        'nav-skills': 'skills',\n        'nav-projetos': 'projetos',\n        'nav-conquistas': 'destaques',\n        'nav-contato': 'contato',\n        'hero-pre': '▮ Olá, mundo. Eu sou',\n        'section-sobre': '// sobre mim',\n        'section-exp': '// experiência & formação',\n        'section-exp-title': 'Trajetória',\n        'section-skills': '// stack técnica',\n        'section-skills-title': 'O que eu uso',\n        'section-projetos': '// projetos selecionados',\n        'section-projetos-title': 'O que eu construí',\n        'section-conquistas': '// destaques',\n        'section-conquistas-title': 'Momentos marcantes',\n        'section-contato': '// contato',\n        'contato-h2': 'Vamos <span class=\"highlight\">conversar</span>?',\n        'contato-p': 'Seja para uma oportunidade, uma parceria ou só para trocar uma ideia sobre QA e IA. Estou disponível.',\n      }\n    };\n\n    function applyLang(lang) {\n      // swap data-en / data-pt inline elements\n      document.querySelectorAll('[data-en]').forEach(el => {\n        if (lang === 'en') {\n          if (!el.dataset.pt) el.dataset.pt = el.innerHTML;\n          el.innerHTML = el.dataset.en;\n        } else {\n          if (el.dataset.pt) el.innerHTML = el.dataset.pt;\n        }\n      });\n\n      // swap keyed static strings\n      const t = staticTranslations[lang];\n      const map = {\n        'nav-sobre': '.nav-links a[href=\"#sobre\"]',\n        'nav-exp': '.nav-links a[href=\"#experiencia\"]',\n        'nav-skills': '.nav-links a[href=\"#skills\"]',\n        'nav-projetos': '.nav-links a[href=\"#projetos\"]',\n        'nav-conquistas': '.nav-links a[href=\"#conquistas\"]',\n        'nav-contato': '.nav-links a[href=\"#contato\"]',\n        'hero-pre': '.hero-pre',\n        'section-sobre': '#sobre .section-label',\n        'section-exp': '#experiencia .section-label',\n        'section-exp-title': '#experiencia .section-title',\n        'section-skills': '#skills .section-label',\n        'section-skills-title': '#skills .section-title',\n        'section-projetos': '#projetos .section-label',\n        'section-projetos-title': '#projetos .section-title',\n        'section-conquistas': '#conquistas .section-label',\n        'section-conquistas-title': '#conquistas .section-title',\n        'section-contato': '#contato .section-label',\n        'contato-h2': '#contato h2',\n        'contato-p': '#contato > .container > .contato-inner > p',\n      };\n      Object.entries(map).forEach(([key, selector]) => {\n        const el = document.querySelector(selector);\n        if (el && t[key] !== undefined) el.innerHTML = t[key];\n      });\n\n      document.documentElement.lang = lang === 'en' ? 'en' : 'pt-BR';\n      langBtn.textContent = lang === 'en' ? 'PT' : 'EN';\n      langBtn.setAttribute('aria-label', lang === 'en' ? 'Mudar para Português' : 'Switch to English');\n      // Amber pulse only when page is in EN (invite to switch to PT)\n      langBtn.classList.toggle('pt-available', lang === 'en');\n      currentLang = lang;\n    }\n\n    langBtn.addEventListener('click', () => {\n      const next = currentLang === 'pt' ? 'en' : 'pt';\n      applyLang(next);\n      dismissHint();\n    });\n\n    // Initialize in English on first load\n    applyLang('en');\n  </script>\n</body>\n</html>\n"
          },
